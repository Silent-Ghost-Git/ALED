{
  "name": "aled",
  "version": "1.0.0",
  "description": "ALED study dashboard (Electron)",
  "main": "electron/main.js",
  "author": "ALED",
  "scripts": {
    "start": "electron .",
    "electron": "electron .",
    "predist": "node scripts/prepare-icon.js",
    "dist": "electron-builder --win msi --x64"
  },
  "build": {
    "appId": "com.github.silentghostgit.aled",
    "productName": "ALED",
    "copyright": "Copyright © ALED",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "style.css",
      "script.js",
      "data/quotes.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon-source.jpg",
        "to": "ALED.jpg"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "ALED",
      "runAfterFinish": true,
      "menuCategory": false
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "jimp": "^0.22.12",
    "to-ico": "^1.1.5"
  },
  "dependencies": {
    "express": "^4.21.1"
  }
}
